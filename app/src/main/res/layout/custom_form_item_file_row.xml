<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="6dp"
    app:cardElevation="1dp"
    app:cardUseCompatPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp">

        <com.huozige.lab.container.offlineform.formitem.file.FileExtensionIconView
            android:id="@+id/fileIconView"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="文件" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/fileNameView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="middle"
                android:singleLine="true"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/fileMetaView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/offline_form_text_content"
                android:textSize="12sp" />

        </LinearLayout>

        <Button
            android:id="@+id/deleteFileButton"
            android:layout_width="72dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/offline_file_delete_button_bg"
            android:contentDescription="删除文件"
            android:drawableStart="@drawable/ic_delete_image"
            android:drawablePadding="4dp"
            android:minWidth="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="删除"
            android:textColor="@color/white"
            android:textSize="13sp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
