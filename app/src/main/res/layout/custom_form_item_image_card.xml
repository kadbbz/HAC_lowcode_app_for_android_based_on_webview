<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="6dp"
    app:cardElevation="1dp"
    app:cardUseCompatPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/imagePreviewContainer"
            android:layout_width="match_parent"
            android:layout_height="140dp">

            <ImageView
                android:id="@+id/imagePreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/imageErrorView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/offline_image_error_bg"
                android:gravity="center"
                android:padding="12dp"
                android:text="@string/offline_text_image_load_failed"
                android:textColor="@color/offline_form_text_content"
                android:textSize="13sp"
                android:visibility="gone" />

        </FrameLayout>

        <Button
            android:id="@+id/deleteImageButton"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="@drawable/offline_image_delete_button_bg"
            android:contentDescription="@string/offline_cd_delete_image"
            android:drawableStart="@drawable/ic_delete_image"
            android:drawablePadding="6dp"
            android:minWidth="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="@string/offline_button_delete"
            android:textColor="@color/white"
            android:textSize="14sp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
