<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <EditText
        android:id="@+id/searchEditText"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/custom_form_bg_edittext_normal"
        android:hint="@string/offline_hint_search"
        android:inputType="text"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:singleLine="true"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/offline_toolbar_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/offline_segmented_control_bg"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="3dp">

            <TextView
                android:id="@+id/cmdFilterUnexported"
                android:layout_width="72dp"
                android:layout_height="34dp"
                android:background="@drawable/offline_segment_tab_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="&#26410;&#23548;&#20986;"
                android:textColor="@color/offline_segment_tab_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/cmdFilterAll"
                android:layout_width="56dp"
                android:layout_height="34dp"
                android:layout_marginStart="2dp"
                android:background="@drawable/offline_segment_tab_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="&#20840;&#37096;"
                android:textColor="@color/offline_segment_tab_text"
                android:textSize="14sp" />

        </LinearLayout>

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <CheckBox
            android:id="@+id/cmdSelectAll"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:buttonTint="@color/huozige_blue"
            android:minWidth="76dp"
            android:text="&#20840;&#36873;"
            android:textColor="@color/offline_form_text_title"
            android:textSize="14sp" />

        <Button
            android:id="@+id/cmdExport"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/offline_button_primary_bg"
            android:minWidth="82dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="&#23548;&#20986;"
            android:textAllCaps="false"
            android:textColor="@color/offline_button_primary_text"
            android:textSize="14sp" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="4dp" />

</LinearLayout>
